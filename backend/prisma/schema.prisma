generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(uuid())
  subdomain   String   @unique
  name        String
  contactEmail String  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  assessments  VaptAssessment[]
  serviceRequests ServiceRequest[]
  invitations  Invitation[]

  @@map("organizations")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  name            String
  role            UserRole @default(CLIENT)
  orgId           String
  resetToken      String?  @unique
  resetTokenExpiry DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization      @relation(fields: [orgId], references: [id])
  sentMessages    Message[]         @relation("SentMessages")
  assessments     VaptAssessment[]  @relation("AssignedAssessments")
  assignedRequests ServiceRequest[] @relation("AssignedRequests")
  sentServiceMessages ServiceMessage[] @relation("SentServiceMessages")
  notifications   Notification[]
  serviceNotifications ServiceNotification[] @relation("ServiceNotifications")
  auditLogs       AuditLog[]
  sentInvitations Invitation[]      @relation("SentInvitations")
  deviceTokens     DeviceToken[]

  @@map("users")
}

enum UserRole {
  ADMIN
  CLIENT
  ANALYST
}

model VaptAssessment {
  id              String            @id @default(uuid())
  orgId           String
  title           String
  scopeDescription String
  targetUrls      String[]
  ipRanges        String[]
  testingType     TestingType
  specialReqs     String?
  status          AssessmentStatus  @default(PENDING)
  assignedAdminId String?
  reportPdfUrl    String?
  reportSummary   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization    Organization      @relation(fields: [orgId], references: [id])
  assignedAdmin   User?             @relation("AssignedAssessments", fields: [assignedAdminId], references: [id])
  messages        Message[]
  attachments     Attachment[]
  findings        Finding[]

  @@map("vapt_assessments")
}

enum TestingType {
  BLACK_BOX
  GREY_BOX
  WHITE_BOX
}

enum AssessmentStatus {
  PENDING
  IN_REVIEW
  APPROVED
  IN_PROGRESS
  REPORTING
  COMPLETE
  ON_HOLD
}

model Message {
  id              String          @id @default(uuid())
  assessmentId    String
  senderId        String
  message         String
  messageType     MessageType     @default(TEXT)
  createdAt       DateTime        @default(now())

  assessment      VaptAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sender          User            @relation("SentMessages", fields: [senderId], references: [id])
  attachments     Attachment[]

  @@map("messages")
}

enum MessageType {
  TEXT
  STATUS_CHANGE
  FILE_UPLOAD
  INTERNAL_NOTE
}

enum StorageProvider {
  LOCAL
  CLOUDINARY
  S3
}

model Attachment {
  id              String          @id @default(uuid())
  assessmentId    String?
  messageId       String?
  fileUrl         String
  fileName        String
  fileSize        Int
  mimeType        String
  uploadedBy      String
  storageProvider StorageProvider @default(LOCAL)
  createdAt       DateTime        @default(now())

  assessment      VaptAssessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  message         Message?        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  assessmentId  String?
  type          NotificationType
  title         String
  message       String
  read          Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  NEW_MESSAGE
  STATUS_CHANGE
  FILE_UPLOAD
  ASSESSMENT_ASSIGNED
  ASSESSMENT_CREATED
}

// ─── Service Requests (all services) ────────────────────────────────────────

enum ServiceType {
  SOFTWARE_DEV
  CYBERSECURITY
  CLOUD
  CONSULTING
}

enum RequestStatus {
  SUBMITTED
  REVIEWED
  SCOPED
  IN_PROGRESS
  REVIEW
  DELIVERED
  CLOSED
  ON_HOLD
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

model ServiceRequest {
  id              String        @id @default(uuid())
  orgId           String
  serviceType     ServiceType
  title           String
  description     String
  metadata        Json          @default("{}")
  status          RequestStatus @default(SUBMITTED)
  assignedAdminId String?
  reportUrl       String?
  reportSummary   String?
  budget          String?
  deadline        DateTime?
  clientFeedback  String?
  clientRating    Int?
  feedbackAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation(fields: [orgId], references: [id])
  assignedAdmin   User?         @relation("AssignedRequests", fields: [assignedAdminId], references: [id])
  messages        ServiceMessage[]
  attachments     ServiceAttachment[]
  findings        ServiceFinding[]
  milestones      Milestone[]
  notifications   ServiceNotification[] @relation("RequestNotifications")

  @@map("service_requests")
}

model ServiceMessage {
  id          String      @id @default(uuid())
  requestId   String
  senderId    String
  message     String
  messageType MessageType @default(TEXT)
  createdAt   DateTime    @default(now())

  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User           @relation("SentServiceMessages", fields: [senderId], references: [id])
  attachments ServiceAttachment[]

  @@map("service_messages")
}

model ServiceAttachment {
  id              String          @id @default(uuid())
  requestId       String?
  messageId       String?
  fileUrl         String
  fileName        String
  fileSize        Int
  mimeType        String
  uploadedBy      String
  storageProvider StorageProvider @default(LOCAL)
  createdAt       DateTime        @default(now())

  request         ServiceRequest?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  message         ServiceMessage?  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("service_attachments")
}

model ServiceFinding {
  id           String        @id @default(uuid())
  requestId    String
  title        String
  description  String
  severity     Severity
  cvssScore    Float?
  category     String
  affectedUrl  String?
  remediation  String
  evidence     String?
  status       FindingStatus @default(OPEN)
  resolvedAt   DateTime?
  resolvedBy   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  request      ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("service_findings")
}

model Milestone {
  id          String          @id @default(uuid())
  requestId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      MilestoneStatus @default(PENDING)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model ServiceNotification {
  id        String           @id @default(uuid())
  userId    String
  requestId String?
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation("ServiceNotifications", fields: [userId], references: [id], onDelete: Cascade)
  request   ServiceRequest?  @relation("RequestNotifications", fields: [requestId], references: [id], onDelete: Cascade)

  @@map("service_notifications")
}

// ─── VAPT Report Findings ───

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED_RISK
  FALSE_POSITIVE
}

model Finding {
  id            String        @id @default(uuid())
  assessmentId  String
  title         String
  description   String
  severity      Severity
  cvssScore     Float?
  category      String
  affectedUrl   String?
  remediation   String
  evidence      String?
  status        FindingStatus @default(OPEN)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assessment    VaptAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("findings")
}

// ─── Portfolio Projects ───

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  tags        String[]
  category    String?
  liveUrl     String?
  previewUrl  String?   // screenshot / cover image URL
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

// ─── Blog / Content ───

model BlogPost {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  author      String
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─── Testimonials ───

model Testimonial {
  id            String    @id @default(uuid())
  clientName    String
  clientRole    String?
  clientCompany String?
  quote         String
  metricValue   String?
  metricLabel   String?
  industry      String?
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@map("testimonials")
}

// ─── Audit Log ───

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_RESET
  ASSESSMENT_CREATE
  ASSESSMENT_UPDATE
  ASSESSMENT_DELETE
  ASSESSMENT_ASSIGN
  MESSAGE_SEND
  FILE_UPLOAD
  FILE_DELETE
  FINDING_CREATE
  FINDING_UPDATE
  FINDING_DELETE
  USER_INVITE
  USER_REMOVE
  SETTINGS_UPDATE
}

model AuditLog {
  id           String     @id @default(uuid())
  userId       String?
  action       AuditAction
  resourceType String?
  resourceId   String?
  details      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── Organization Invitations ───

model Invitation {
  id        String    @id @default(uuid())
  email     String
  orgId     String
  invitedBy String
  role      UserRole  @default(CLIENT)
  token     String    @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter      User         @relation("SentInvitations", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([email, orgId])
  @@map("invitations")
}

// ─── Push Notification Device Tokens ───

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String   @default("web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("device_tokens")
}

// ─── Analytics Events ───

model AnalyticsEvent {
  id        String   @id @default(uuid())
  type      String   // PAGE_VIEW, CLICK, CUSTOM
  page      String   // e.g. "/", "/about", "home"
  label     String?  // e.g. "Request Assessment"
  country   String?
  region    String?
  city      String?
  ip        String?
  userAgent String?
  referrer  String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([page, createdAt])
  @@index([country, createdAt])
  @@map("analytics_events")
}
