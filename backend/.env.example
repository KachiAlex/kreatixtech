DATABASE_URL="postgresql://username:password@localhost:5432/kreatix_vapt?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
PORT=5000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production example: https://kreatixtech.vercel.app,https://www.kreatixtech.com
# Local dev: http://localhost:5173
FRONTEND_URL="http://localhost:5173"

UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET="your-admin-secret-key"

# ─── Resend email ─────────────────────────────────────────────────────────────
# Get API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
RESEND_SENDER_EMAIL="onboarding@resend.dev"
RESEND_SENDER_NAME="Kreatix Technologies"

# Contact form destination
CONTACT_EMAIL="info@kreatixtech.com"
