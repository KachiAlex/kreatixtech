# ─── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# In production (Vercel), set these as environment variables in the dashboard.

# Backend API URL
# Local dev: leave unset — Vite proxies /api/* to http://localhost:5000
# Production: point at the fly.io backend
VITE_API_URL=https://kreatixtech.fly.dev

# EmailJS (used by the contact form)
# Sign up at https://www.emailjs.com (free tier: 200 emails/month)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
